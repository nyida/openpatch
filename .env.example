# --- LLM: 5 free Ollama models. No API key required. ---
# OLLAMA_BASE_URL="http://localhost:11434/v1"
# OLLAMA_MODEL="llama3.2"
# OLLAMA_EMBED_MODEL="nomic-embed-text"
# Fast (small) models: ollama pull llama3.2:1b && ollama pull qwen2.5:0.5b && ollama pull mistral && ollama pull phi3:mini && ollama pull gemma2:2b
# For embeddings (RAG): ollama pull nomic-embed-text
#
# --- Parallel 5 models (saves time): run 5 Ollama instances on 5 ports, one model each ---
# OLLAMA_URLS="http://localhost:11434/v1,http://localhost:11435/v1,http://localhost:11436/v1,http://localhost:11437/v1,http://localhost:11438/v1"
# Start 5 instances: OLLAMA_HOST=127.0.0.1:11435 ollama serve &  (repeat for 11436..11438), or use 5 terminals.
# CANDIDATE_COUNT=1  (default) = one LLM call, no judge, ~20–40s. Set CANDIDATE_COUNT=5 + OLLAMA_URLS for multi-model + judge (~60s+ with 5 instances).
# TAVILY_ENABLED=true  (optional) to enable web search when no docs/URLs; off by default for speed.
# Tavily (below) provides web search when user has no URLs/docs.

DATABASE_URL="postgresql://user:password@localhost:5432/openpatch?schema=public"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ENCRYPTION_KEY="32-byte-hex-key-for-api-keys"
VERSION_TAG="dev"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=10

# Web search (Tavily) for finding and captioning web content when user has no URLs/docs
TAVILY_API_KEY="tvly-..."
