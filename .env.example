# Use OpenRouter for multiple models (OpenAI, Claude, etc.) with one key
OPENROUTER_API_KEY="sk-or-v1-..."

# Or use OpenAI directly
OPENAI_API_KEY="sk-..."

DATABASE_URL="postgresql://user:password@localhost:5432/openpatch?schema=public"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ENCRYPTION_KEY="32-byte-hex-key-for-api-keys"
VERSION_TAG="dev"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=10
