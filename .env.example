# --- LLM: Choose one of (A) Ollama, (B) OpenRouter, or (C) OpenAI ---
# (A) Ollama (local, free): OLLAMA_BASE_URL or OLLAMA_URLS. No API key.
#    USE_OLLAMA=true forces Ollama even when cloud keys exist (avoids OpenRouter connection issues).
# (B) OpenRouter (cloud): OPENROUTER_API_KEY. Use when deploying to Vercel etc. (no Ollama).
# (C) OpenAI: OPENAI_API_KEY. Alternative cloud option.
# If none of OLLAMA_BASE_URL/OLLAMA_URLS/USE_OLLAMA set, app uses OPENROUTER_API_KEY or OPENAI_API_KEY.
#
# --- Ollama (local dev) ---
# OLLAMA_BASE_URL="http://localhost:11434/v1"
# OLLAMA_MODEL="llama3.2"
# OLLAMA_EMBED_MODEL="nomic-embed-text"
# OLLAMA_URLS="http://localhost:11434/v1,..."  # Parallel multi-instance
#
# --- Cloud (production, e.g. Vercel) ---
# OPENROUTER_API_KEY="sk-or-..."   # openrouter.ai - one key for many models
# OPENAI_API_KEY="sk-..."         # Or use OpenAI directly
# OPENROUTER_MODEL="openai/gpt-4o-mini"  # optional override
# OPENAI_MODEL="gpt-4o-mini"              # optional override
#
# CANDIDATE_COUNT=3  (default). Set 1 for fastest (single call, no judge).
# IMPROVED_N_CANDIDATES=1  for fastest Improved mode (1 candidate, no judge).
# TURBO_MAX_TOKENS=576  (default). 384=fastest, 768=longer answers.

# Local: direct Postgres. Vercel: use Supabase pooler (port 6543), not direct (5432).
DATABASE_URL="postgresql://user:password@localhost:5432/openpatch?schema=public"
ENCRYPTION_KEY="32-byte-hex-key-for-api-keys"
VERSION_TAG="dev"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=10

# Supabase Auth (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
# Google/GitHub OAuth: add credentials in Supabase Dashboard > Authentication > Providers

# Web search (images + context from the web)
# Tavily: when TAVILY_API_KEY is set, web search runs by default. Set TAVILY_ENABLED=false to disable.
# TAVILY_API_KEY="tvly-..."
# TAVILY_ENABLED=false  # Set to false to disable (default: on when key exists)
# SearXNG: free, self-hosted alternative. Use when TAVILY_API_KEY is not set.
# SEARXNG_BASE_URL="http://localhost:8080"
# SEARXNG_ENABLED=true  # cd searxng && docker compose up -d

# CORTEX mode (optional Python backend)
# CORTEX_API_URL="http://localhost:8000"
